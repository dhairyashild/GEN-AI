## PROD: RecursiveCharacterTextSplitter(1000,150,add_start_index=True) ⭐

from langchain_text_splitters import (
    RecursiveCharacterTextSplitter, CharacterTextSplitter, TokenTextSplitter, 
    MarkdownTextSplitter, PythonCodeTextSplitter, Language
)

# 1️⃣ RECURSIVE (95% RAG) - Para→Sentence→Word # ← BOTH WAYS HERE!
# WAY 1: POSITIONAL (SHORT) - CHANGE 1st=size, 2nd=overlap
r1 = RecursiveCharacterTextSplitter(1000,150,add_start_index=True)  # # ← 1000=size,150=overlap
# WAY 2: NAMED (EXPLICIT)
r2 = RecursiveCharacterTextSplitter(
    chunk_size=1000,      # # ← CHANGE chunk_size HERE
    chunk_overlap=150,    # # ← CHANGE chunk_overlap HERE
    add_start_index=True
)
chunks = r1.split_text(document)  # Articles/PDFs ✅

# 2️⃣ CHARACTER from_tiktoken (Token-accurate)
c = CharacterTextSplitter.from_tiktoken_encoder("cl100k_base",1000,150)

# 3️⃣ TOKEN (LLM Native)
t = TokenTextSplitter(300,50,encoding_name="cl100k_base")

# 4️⃣ MARKDOWN (Structure)
m = MarkdownTextSplitter(1000,100)  # Headers # ##

# 5️⃣ PYTHON CODE
p = PythonCodeTextSplitter.from_language(Language.PYTHON,1000,100)

## EXTRA PROD NOTES:
# ✅ Length-based: Recursive(1000,150) + Token(cl100k_base)
# ✅ Structure-based: Markdown/Code splitters preserve logic
# ✅ add_start_index=True → UI citations
# ✅ 1000chars≈250tokens → GPT-4o(128k) fits 500 chunks
# # TO CHANGE: 1st #=1000→2000(size), 2nd #=150→200(overlap)

