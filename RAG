###### PROD-ESSENTIAL + S3/FireCrawl/PyMuPDF (Site Examples + Chunking) ######

from langchain_community.document_loaders import (
    PyMuPDFLoader, DirectoryLoader, S3DirectoryLoader, GCSDirectoryLoader, FireCrawlLoader
)
from langchain_text_splitters import RecursiveCharacterTextSplitter

text_splitter = RecursiveCharacterTextSplitter(chunk_size=1000, chunk_overlap=50)

# 1️⃣ S3 DIRECTORY (AWS Docs) → LOAD → SPLIT
s3_docs = S3DirectoryLoader("testing-hwc", prefix="docs/").load()  # pip install boto3
s3_chunks = text_splitter.split_documents(s3_docs)

# 2️⃣ S3 w/ CREDENTIALS (AWS Docs)
s3_creds_docs = S3DirectoryLoader(
    "testing-hwc", 
    prefix="fake/",
    aws_access_key_id="xxxx", 
    aws_secret_access_key="yyyy"
).load()
s3_creds_chunks = text_splitter.split_documents(s3_creds_docs)

# 3️⃣ PYMuPDF (Site Example) → LOAD → SPLIT
pdf_docs = PyMuPDFLoader("./example_data/layout-parser-paper.pdf").load()
pdf_chunks = text_splitter.split_documents(pdf_docs)

# 4️⃣ FIRECRAWL SCRAPE (Site Docs)
fire_docs = FireCrawlLoader(
    api_key="YOUR_API_KEY", 
    url="https://firecrawl.dev", 
    mode="scrape"  # or "crawl", "map"
).load()
fire_chunks = text_splitter.split_documents(fire_docs)

# 5️⃣ FIRECRAWL LAZY LOAD (Production - Large Sites)
pages = []
loader = FireCrawlLoader(api_key="YOUR_API_KEY", url="https://firecrawl.dev", mode="crawl")
for doc in loader.lazy_load():
    pages.append(doc)
    if len(pages) >= 10:  # Batch upsert to vector store
        pages_chunks = text_splitter.split_documents(pages)
        # vectorstore.add_documents(pages_chunks)
        pages = []

# ALL READY
all_chunks = s3_chunks + pdf_chunks + fire_chunks + pages_chunks
