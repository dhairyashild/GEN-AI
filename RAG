from langchain_community.document_loaders import (
    PyMuPDFLoader, 
    DirectoryLoader, 
    WebBaseLoader, 
    S3DirectoryLoader, 
    GCSDirectoryLoader, 
    TextLoader,
    AzureBlobStorageContainerLoader,
    ConfluenceLoader
)
from langchain_text_splitters import RecursiveCharacterTextSplitter

# 1. HIGH-SPEED LOCAL PDF (PyMuPDF is the industry standard for speed)
loader_pdf = PyMuPDFLoader("manual.pdf")
docs_pdf = loader_pdf.load()

# 2. MULTI-THREADED DIRECTORY LOAD (Essential for large local datasets)
# use_multithreading=True significantly cuts down ingestion time in PROD
loader_dir = DirectoryLoader(
    "./knowledge_base", 
    glob="**/*.pdf", 
    loader_cls=PyMuPDFLoader,
    use_multithreading=True,
    show_progress=True
)
docs_dir = loader_dir.load()

# 3. CLOUD STORAGE: AWS S3 (Requires boto3)
# Best practice: Use prefixes to limit scan range
loader_s3 = S3DirectoryLoader("prod-bucket", prefix="documents/")
docs_s3 = loader_s3.load()

# 4. CLOUD STORAGE: GOOGLE CLOUD (Requires google-cloud-storage)
loader_gcs = GCSDirectoryLoader(project_name="ai-project", bucket="legal-docs")
docs_gcs = loader_gcs.load()

# 5. CLOUD STORAGE: AZURE BLOB (Requires azure-storage-blob)
loader_azure = AzureBlobStorageContainerLoader(conn_str="AZURE_CONN_STR", container="data")
docs_azure = loader_azure.load()

# 6. WEB SCRAPING (With User-Agent to avoid 403 Forbidden errors)
loader_web = WebBaseLoader(
    "https://docs.example.com",
    header_template={"User-Agent": "Mozilla/5.0"} 
)
docs_web = loader_web.load()

# 7. ENTERPRISE SAAS: CONFLUENCE (Common in Corporate RAG)
loader_conf = ConfluenceLoader(url="https://yoursite.atlassian.net", space_key="TECH")
docs_conf = loader_conf.load()

# 8. PLAIN TEXT (Explicit encoding prevents crashes on special characters)
loader_txt = TextLoader("logs.txt", encoding="utf-8")
docs_txt = loader_txt.load()

# UNIFIED PROCESSING
all_docs = docs_pdf + docs_dir + docs_s3 + docs_gcs + docs_azure + docs_web + docs_conf + docs_txt

# PRODUCTION SPLITTING STRATEGY
# 1000/200 is the 'Goldilocks' zone for most LLM context windows
splitter = RecursiveCharacterTextSplitter(
    chunk_size=1000, 
    chunk_overlap=200,
    add_start_index=True # Helpful for referencing source location
)
final_chunks = splitter.split_documents(all_docs)
