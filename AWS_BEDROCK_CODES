from langchain_aws import BedrockEmbeddings
                                  # Professional Standard: No keys, no profiles, just the Model & Region
                                              # This uses 'Instance Profiles' or 'Task Roles' in the cloud
embeddings = BedrockEmbeddings(
    model_id="amazon.titan-embed-text-v2:0",      # Specifies the exact embedding engine
    region_name="us-east-1"                        # Points to the data center location
)
# Execution
vector = embeddings.embed_query("Real-time AI Engineering content")          # Converts text to math
print(f"Vector dimensions: {len(vector)}")                               # Verifies the output size
